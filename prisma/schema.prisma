generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum PlatformRole {
  SUPER_ADMIN
  USER
}

enum CompanyStatus {
  ACTIVE
  SUSPENDED
  TRIAL
}

enum MembershipRole {
  OWNER
  ADMIN
  TECH
  BILLING
  VIEWER
}

enum IntegrationType {
  PRTG
  BACKUP
  RMM
  PSA
  CUSTOM
}

enum IntegrationStatus {
  DRAFT
  ACTIVE
  ERROR
  PAUSED
}

enum LicenseStatus {
  ACTIVE
  EXPIRING
  EXPIRED
  CANCELLED
}

enum RecordSeverity {
  INFO
  WARNING
  CRITICAL
}

enum CrmClientType {
  PARTICULAR
  EMPRESA
  AUTONOMO
  COMUNIDAD
  OTRO
}

enum CrmClientStatus {
  ACTIVE
  INACTIVE
  LEAD
  ARCHIVED
}

enum ServiceRequestStatus {
  NEW
  CONTACTED
  IN_PROGRESS
  CLOSED
  LOST
}

enum RequestUrgency {
  LOW
  NORMAL
  HIGH
  URGENT
}

enum QuoteStatus {
  DRAFT
  SENT
  ACCEPTED
  REJECTED
}

enum ReminderStatus {
  PENDING
  COMPLETED
}

enum ReminderType {
  CALL
  RENEWAL
  PAYMENT
  MAINTENANCE
  OTHER
}

enum TemplateType {
  WHATSAPP
  EMAIL
  QUOTE
  FOLLOW_UP
}

enum ServiceBillingStatus {
  PENDING_PAYMENT
  INVOICED
  PAID
}

model User {
  id                String       @id @default(cuid())
  email             String       @unique
  name              String
  passwordHash      String
  platformRole      PlatformRole @default(USER)
  isActive          Boolean      @default(true)
  lastLoginAt       DateTime?
  passwordChangedAt DateTime     @default(now())
  createdAt         DateTime     @default(now())
  updatedAt         DateTime     @updatedAt

  memberships Membership[]
  auditLogs   AuditLog[]
}

model Company {
  id        String        @id @default(cuid())
  name      String
  slug      String        @unique
  taxId     String?
  status    CompanyStatus @default(TRIAL)
  plan      String        @default("starter")
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt

  memberships       Membership[]
  integrations      Integration[]
  licenses          License[]
  records           OperationalRecord[]
  auditLogs         AuditLog[]
  crmClients        CrmClient[]
  serviceRequests   ServiceRequest[]
  quotes            Quote[]
  serviceJobs       ServiceJob[]
  reminders         Reminder[]
  templates         Template[]
  priceItems        PriceItem[]
  clientAttachments ClientAttachment[]
}

model Membership {
  id        String         @id @default(cuid())
  role      MembershipRole @default(VIEWER)
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt

  userId    String
  user      User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  companyId String
  company   Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@unique([userId, companyId])
  @@index([companyId, role])
}

model Integration {
  id              String            @id @default(cuid())
  type            IntegrationType
  name            String
  baseUrl         String?
  status          IntegrationStatus @default(DRAFT)
  encryptedSecret String?
  settings        Json?
  lastSyncAt      DateTime?
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt

  companyId String
  company   Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  records OperationalRecord[]

  @@unique([companyId, type, name])
  @@index([companyId, type])
}

model License {
  id            String        @id @default(cuid())
  provider      String
  product       String
  seats         Int           @default(1)
  status        LicenseStatus @default(ACTIVE)
  purchaseDate  DateTime?
  renewalDate   DateTime?
  costCents     Int?
  currency      String        @default("EUR")
  vendorAccount String?
  notes         String?
  metadata      Json?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  companyId String
  company   Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@unique([companyId, provider, product])
  @@index([companyId, renewalDate])
  @@index([companyId, status])
}

model OperationalRecord {
  id         String         @id @default(cuid())
  source     String
  title      String
  detail     String?
  severity   RecordSeverity @default(INFO)
  occurredAt DateTime       @default(now())
  metadata   Json?
  createdAt  DateTime       @default(now())

  companyId     String
  company       Company      @relation(fields: [companyId], references: [id], onDelete: Cascade)
  integrationId String?
  integration   Integration? @relation(fields: [integrationId], references: [id], onDelete: SetNull)

  @@index([companyId, occurredAt])
  @@index([companyId, severity])
}

model CrmClient {
  id          String          @id @default(cuid())
  name        String
  companyName String?
  clientType  CrmClientType   @default(PARTICULAR)
  phone       String?
  email       String?
  address     String?
  notes       String?
  status      CrmClientStatus @default(ACTIVE)
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  companyId String
  company   Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  requests    ServiceRequest[]
  quotes      Quote[]
  services    ServiceJob[]
  reminders   Reminder[]
  attachments ClientAttachment[]

  @@index([companyId, status])
  @@index([companyId, name])
}

model ServiceRequest {
  id          String               @id @default(cuid())
  name        String
  phone       String?
  email       String?
  serviceType String
  description String
  urgency     RequestUrgency       @default(NORMAL)
  status      ServiceRequestStatus @default(NEW)
  createdAt   DateTime             @default(now())
  updatedAt   DateTime             @updatedAt

  companyId String
  company   Company    @relation(fields: [companyId], references: [id], onDelete: Cascade)
  clientId  String?
  client    CrmClient? @relation(fields: [clientId], references: [id], onDelete: SetNull)

  @@index([companyId, status])
  @@index([companyId, createdAt])
}

model Quote {
  id            String      @id @default(cuid())
  quoteNumber   String?
  title         String
  status        QuoteStatus @default(DRAFT)
  notes         String?
  conditions    String?
  subtotalCents Int         @default(0)
  taxCents      Int         @default(0)
  totalCents    Int         @default(0)
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  companyId String
  company   Company   @relation(fields: [companyId], references: [id], onDelete: Cascade)
  clientId  String
  client    CrmClient @relation(fields: [clientId], references: [id], onDelete: Cascade)

  lines QuoteLine[]

  @@unique([companyId, quoteNumber])
  @@index([companyId, status])
  @@index([companyId, createdAt])
}

model QuoteLine {
  id         String   @id @default(cuid())
  concept    String
  quantity   Decimal  @default(1) @db.Decimal(10, 2)
  priceCents Int
  vatRate    Decimal  @default(21) @db.Decimal(5, 2)
  totalCents Int
  createdAt  DateTime @default(now())

  quoteId     String
  quote       Quote      @relation(fields: [quoteId], references: [id], onDelete: Cascade)
  priceItemId String?
  priceItem   PriceItem? @relation(fields: [priceItemId], references: [id], onDelete: SetNull)

  @@index([quoteId])
  @@index([priceItemId])
}

model ServiceJob {
  id            String               @id @default(cuid())
  serviceDate   DateTime             @default(now())
  description   String
  minutesSpent  Int?
  priceCents    Int?
  billingStatus ServiceBillingStatus @default(PENDING_PAYMENT)
  observations  String?
  createdAt     DateTime             @default(now())
  updatedAt     DateTime             @updatedAt

  companyId String
  company   Company   @relation(fields: [companyId], references: [id], onDelete: Cascade)
  clientId  String
  client    CrmClient @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@index([companyId, serviceDate])
  @@index([companyId, billingStatus])
  @@index([clientId])
}

model PriceItem {
  id          String   @id @default(cuid())
  name        String
  description String?
  priceCents  Int
  vatRate     Decimal  @default(21) @db.Decimal(5, 2)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  companyId String
  company   Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  quoteLines QuoteLine[]

  @@unique([companyId, name])
  @@index([companyId, isActive])
}

model ClientAttachment {
  id        String   @id @default(cuid())
  title     String
  url       String
  notes     String?
  createdAt DateTime @default(now())

  companyId String
  company   Company   @relation(fields: [companyId], references: [id], onDelete: Cascade)
  clientId  String
  client    CrmClient @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@index([companyId, createdAt])
  @@index([clientId])
}

model Reminder {
  id        String         @id @default(cuid())
  title     String
  dueDate   DateTime
  status    ReminderStatus @default(PENDING)
  type      ReminderType   @default(OTHER)
  notes     String?
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt

  companyId String
  company   Company    @relation(fields: [companyId], references: [id], onDelete: Cascade)
  clientId  String?
  client    CrmClient? @relation(fields: [clientId], references: [id], onDelete: SetNull)

  @@index([companyId, status, dueDate])
}

model Template {
  id        String       @id @default(cuid())
  name      String
  type      TemplateType
  content   String
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt

  companyId String
  company   Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@unique([companyId, type, name])
  @@index([companyId, type])
}

model AuditLog {
  id        String   @id @default(cuid())
  action    String
  entity    String
  entityId  String?
  ipAddress String?
  userAgent String?
  metadata  Json?
  createdAt DateTime @default(now())

  userId    String?
  user      User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  companyId String?
  company   Company? @relation(fields: [companyId], references: [id], onDelete: SetNull)

  @@index([companyId, createdAt])
  @@index([userId, createdAt])
}
